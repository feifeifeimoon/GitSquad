# GitSquad — local development configuration.
# Copy this file to .env and fill in the required values.


# GITSQUAD_JWT_SECRET=change-me-in-production
# GITSQUAD_FRONTEND_URL=http://localhost:3000

# Server
GITSQUAD_ENV=development
GITSQUAD_HTTP_ADDR=:8080
GITSQUAD_DATABASE_URL=postgres://gitsquad:gitsquad@localhost:5432/gitsquad?sslmode=disable

# Google OAuth (required — register at https://console.cloud.google.com/apis/credentials)
GITSQUAD_GOOGLE_CLIENT_ID=
GITSQUAD_GOOGLE_CLIENT_SECRET=
# GITSQUAD_GOOGLE_CALLBACK_URL=http://localhost:8080/api/v1/auth/google/callback

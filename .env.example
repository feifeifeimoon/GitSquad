# GitSquad local development configuration.
GITSQUAD_ENV=development
GITSQUAD_HTTP_ADDR=:8080
GITSQUAD_DATABASE_URL=postgres://gitsquad:gitsquad@localhost:5432/gitsquad?sslmode=disable

GITSQUAD_GITHUB_WEBHOOK_SECRET=
GITSQUAD_GITHUB_APP_ID=
GITSQUAD_GITHUB_PRIVATE_KEY_PATH=

GITSQUAD_API_URL=http://localhost:8080
GITSQUAD_DAEMON_TOKEN=
GITSQUAD_DAEMON_WORK_DIR=.gitsquad/workspaces
GITSQUAD_ENABLE_PGVECTOR=false
